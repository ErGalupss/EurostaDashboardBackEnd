// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  domain      String?  @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  uiConfigs   UiConfigVersion[]
  menuItems   MenuItem[]
  featureFlags FeatureFlag[]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  roleId    String
  role      Role     @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String       @id @default(uuid())
  name        String       @unique
  permissions Permission[] @relation("RolePermissions")
  users       User[]
}

model Permission {
  id    String @id @default(uuid())
  name  String @unique
  roles Role[] @relation("RolePermissions")
}

model FeatureFlag {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?
  enabled     Boolean  @default(false)
  rollout     Int      @default(100) // 0-100
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UiConfigVersion {
  id          String   @id @default(uuid())
  version     Int
  config      Json     // The full UI bootstrap JSON
  published   Boolean  @default(false)
  environment String   // dev, staging, prod
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  createdBy   String
  updatedBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([version, tenantId, environment])
}

model MenuItem {
  id          String   @id @default(uuid())
  label       String
  icon        String?
  path        String?
  order       Int      @default(0)
  parentId    String?
  parent      MenuItem? @relation("MenuHierarchy", fields: [parentId], references: [id])
  children    MenuItem[] @relation("MenuHierarchy")
  permissions String[] // Required permission names
  visible     Boolean  @default(true)
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
}

model LayoutBlock {
  id          String   @id @default(uuid())
  page        String   // e.g., "dashboard", "settings"
  type        String   // e.g., "grid", "section", "tabs"
  config      Json
  order       Int      @default(0)
  tenantId    String?
}

model Widget {
  id          String   @id @default(uuid())
  name        String
  type        String   // e.g., "chart", "metric", "table"
  config      Json
  permissions String[]
  tenantId    String?
}

model DynamicForm {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  fields      FormField[]
  tenantId    String?
}

model FormField {
  id            String      @id @default(uuid())
  formId        String
  form          DynamicForm @relation(fields: [formId], references: [id])
  name          String
  label         String
  type          String      // text, select, number, date
  required      Boolean     @default(false)
  validation    Json?       // regex, min, max, etc.
  options       Json?       // for select type
  order         Int         @default(0)
  conditional   Json?       // rules for visibility
}

model WorkflowState {
  id          String   @id @default(uuid())
  workflowKey String   // e.g., "order_process"
  name        String
  label       String
  color       String?
  isInitial   Boolean  @default(false)
  isFinal     Boolean  @default(false)
  tenantId    String?
  transitions WorkflowTransition[] @relation("FromState")
  incoming    WorkflowTransition[] @relation("ToState")
}

model WorkflowTransition {
  id          String   @id @default(uuid())
  fromStateId String
  fromState   WorkflowState @relation("FromState", fields: [fromStateId], references: [id])
  toStateId   String
  toState     WorkflowState @relation("ToState", fields: [toStateId], references: [id])
  action      String        // e.g., "approve", "reject"
  permissions String[]      // roles allowed to trigger this
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String
  entityType  String
  entityId    String
  oldValue    Json?
  newValue    Json?
  userId      String
  createdAt   DateTime @default(now())
}
